{
  "buildCommand": "cd landing && npm ci && npm run build",
  "outputDirectory": "landing/dist",
  "routes": [
    {
      "src": "/editor",
      "dest": "/editor/index.html"
    },
    {
      "src": "/editor/(.*)",
      "dest": "/editor/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
